// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String?
  lastName      String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  brands        Brand[]
  accounts      OAuthAccount[]
  posts         Post[]
  media         Media[]
  
  @@index([email])
}

model Brand {
  id            String    @id @default(cuid())
  userId        String
  name          String
  logo          String?
  description   String?
  website       String?
  slug          String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts      OAuthAccount[]
  posts         Post[]
  analytics     Analytics[]
  
  @@index([userId])
  @@index([slug])
}

model OAuthAccount {
  id            String    @id @default(cuid())
  userId        String
  brandId       String
  platform      String    // facebook, instagram, youtube, tiktok, linkedin
  accountId     String
  accountName   String
  accessToken   String
  refreshToken  String?
  tokenExpiresAt DateTime?
  profileData   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand         Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  
  @@unique([brandId, platform, accountId])
  @@index([userId])
  @@index([brandId])
}

model Post {
  id            String    @id @default(cuid())
  userId        String
  brandId       String
  title         String?
  content       String
  scheduledAt   DateTime?
  publishedAt   DateTime?
  platforms     String[]  // array of platform names
  status        String    @default("draft") // draft, scheduled, published, failed
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand         Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  media         PostMedia[]
  
  @@index([userId])
  @@index([brandId])
  @@index([status])
  @@index([scheduledAt])
}

model PostMedia {
  id            String    @id @default(cuid())
  postId        String
  mediaId       String
  order         Int       @default(0)
  
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([mediaId])
  @@unique([postId, mediaId])
}

model Media {
  id            String    @id @default(cuid())
  userId        String
  key           String    // S3 key or file path
  url           String
  type          String    // image, video, document
  mimeType      String
  size          Int
  width         Int?
  height        Int?
  duration      Int?      // for videos, in seconds
  metadata      Json?
  createdAt     DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts         PostMedia[]
  
  @@index([userId])
}

model Analytics {
  id            String    @id @default(cuid())
  brandId       String
  platform      String
  date          DateTime
  views         Int       @default(0)
  engagement    Int       @default(0)
  clicks        Int       @default(0)
  shares        Int       @default(0)
  comments      Int       @default(0)
  likes         Int       @default(0)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  brand         Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  
  @@index([brandId])
  @@index([date])
  @@unique([brandId, platform, date])
}
